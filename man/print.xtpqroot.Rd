\name{print.xtpqroot}
\alias{print.xtpqroot}
\title{Print Method for xtpqroot Objects}
\description{
  Prints a formatted summary of an \code{"xtpqroot"} test result.
}
\usage{
\method{print}{xtpqroot}(x, \dots)
}
\arguments{
  \item{x}{An object of class \code{"xtpqroot"}.}
  \item{\dots}{Additional arguments (ignored).}
}
\value{
  Invisibly returns \code{x}.
}
\keyword{print}
