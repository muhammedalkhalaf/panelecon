\name{print.xtpcaus}
\alias{print.xtpcaus}
\title{Print Method for xtpcaus Objects}
\description{Prints a formatted summary of an \code{"xtpcaus"} result.}
\usage{
\method{print}{xtpcaus}(x, \dots)
}
\arguments{
  \item{x}{An object of class \code{"xtpcaus"}.}
  \item{\dots}{Additional arguments (ignored).}
}
\value{Invisibly returns \code{x}.}
\keyword{print}
